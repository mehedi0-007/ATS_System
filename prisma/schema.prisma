generator client {
  provider = "prisma-client-js"
  // output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum ResumeStatus {
  UPLOADED
  PARSING
  READY
  FAILED
}

enum AnalysisStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum BackgroundJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum BackgroundJobType {
  PARSE_RESUME
  ANALYZE_RESUME
}

model User {
  id       String   @id @default(uuid())
  name     String
  email    String   @unique
  password String
  role     UserRole @default(USER)

  resumes          Resume[]
  refreshTokenHash String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  jobs      Job[]
}

model Resume {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title            String
  originalFileName String
  storedFileName   String

  mimeType String
  fileSize Int

  parsedText String?
  status     ResumeStatus @default(UPLOADED)

  analyses       ResumeAnalysis[]
  backgroundJobs BackgroundJob[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Job {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title       String
  company     String?
  description String

  isSaved Boolean @default(false)

  analyses ResumeAnalysis[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model ResumeAnalysis {
  id String @id @default(uuid())

  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  status AnalysisStatus @default(PENDING)

  atsScore Int?

  matchedSkills Json?
  missingSkills Json?
  suggestions   Json?

  summary String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([resumeId, jobId])
  @@index([resumeId])
  @@index([jobId])
}

model BackgroundJob {
  id String @id @default(uuid())

  resumeId String
  resume   Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  type BackgroundJobType

  status BackgroundJobStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([resumeId])
}
